{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "manzil",
  "version": "1.0.0",
  "identifier": "com.fauzim.manzil",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "bun dev",
    "beforeBuildCommand": "bun build ./src/index.html --outdir ./dist",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Manzil",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
